{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VirusClaw Desktop",
  "version": "0.1.0",
  "identifier": "com.virusclaw.desktop",
  "build": {
    "beforeDevCommand": "pnpm prepare:agent-browser && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm prepare:agent-browser && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VirusClaw Desktop",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": [
      "resources/agent-browser/**/*"
    ],
    "icon": [
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
